<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Header bar -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#111111"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SpyderMusic Auth"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:contentDescription="SpyderMusic Auth" />

        <TextView
            android:id="@+id/version_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#555555"
            android:textSize="12sp" />

    </LinearLayout>

    <!--
        FIX #6: 3dp brand-red accent line below the header ties the visual
        identity together without being loud. Uses colorPrimary (#FF4444).
    -->
    <View
        android:id="@+id/header_accent"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="#FF4444"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent" />

    <!--
        FIX #3: horizontal ProgressBar immediately below the accent line.
        Driven by WebChromeClient.onProgressChanged; hidden when load completes.
    -->
    <ProgressBar
        android:id="@+id/loading_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:max="100"
        android:progressTint="#FF4444"
        android:progressBackgroundTint="#1A1A1A"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/header_accent"
        app:layout_constraintStart_toStartOf="parent" />

    <!--
        Card container — fixed minHeight so the WebView anchor never shifts
        regardless of how much text the status card holds.
        status_card, success_card, and grant_access_button are stacked inside;
        only the relevant one is visible at a time.
    -->
    <FrameLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/loading_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Status card — loading / instructions / errors -->
        <LinearLayout
            android:id="@+id/status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_status"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="60dp">

            <!--
                FIX #2: minLines="2" prevents the card collapsing to a single
                line on short messages, which would shift the WebView up/down.
            -->
            <TextView
                android:id="@+id/status_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading YouTube Music…"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:minLines="2" />

            <!--
                FIX #4: "Grant Access" button shown only on API 30+ when
                MANAGE_EXTERNAL_STORAGE has not yet been granted. Hidden by
                default; made VISIBLE in code before the user is prompted.
            -->
            <Button
                android:id="@+id/grant_access_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Grant Access"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4444"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Success card — shown briefly after successful capture -->
        <LinearLayout
            android:id="@+id/success_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_success"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:minHeight="60dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✓  Session captured — Kodi has been notified"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

    <!-- WebView — anchored to the card container, fills remaining space -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="YouTube Music"
        app:layout_constraintTop_toBottomOf="@id/card_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
