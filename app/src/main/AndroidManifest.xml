<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- API 21-28: legacy external storage — no runtime request needed on API 21-22,
         runtime request required on API 23-28. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- API 30+ (Android 11+): scoped storage — MANAGE_EXTERNAL_STORAGE is the
         only way to write to arbitrary public directories. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Required for startForegroundService() on API 28+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- API 34+: foreground service type must be declared -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!--
        SHIELD TV FIX: Shield TV has no touchscreen. Without this declaration,
        Android's package manager rejects any APK that implicitly requires
        android.hardware.touchscreen.
    -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:name=".SpyderMusicApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="SpyderMusic Auth"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpyderMusicAuth"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                SHIELD TV FIX: LEANBACK_LAUNCHER makes the app appear in the
                Shield / Android TV app drawer after installation.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

            <!-- Deep link from Kodi: spydermusic://auth -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="spydermusic" android:host="auth" />
            </intent-filter>

        </activity>

        <!--
            CookieRefreshService — headless WebView service for background refresh.
            foregroundServiceType="dataSync" required on API 34 (targetSdk 34).
        -->
        <service
            android:name=".CookieRefreshService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
