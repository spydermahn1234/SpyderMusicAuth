<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- API 21-28: legacy external storage — no runtime request needed on API 21-22,
         runtime request required on API 23-28. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!--
        FIX #12: READ_EXTERNAL_STORAGE removed. It was declared but never requested at
        runtime, and on API 29 it is automatically co-granted with WRITE_EXTERNAL_STORAGE,
        so declaring it separately was dead manifest weight. On API 30+ it is superseded
        by MANAGE_EXTERNAL_STORAGE entirely.
    -->
    <!-- API 30+ (Android 11+): scoped storage — MANAGE_EXTERNAL_STORAGE is the
         only way to write to arbitrary public directories. User is directed to
         the system "All files access" settings page on first launch. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!--
        SHIELD TV FIX: Shield TV has no touchscreen. Without this declaration,
        Android's package manager rejects any APK that implicitly requires
        android.hardware.touchscreen — which all apps do by default.
        Setting required="false" allows installation and sideloading on Shield
        and other Android TV devices, while still working normally on phones/tablets.
    -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="SpyderMusic Auth"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpyderMusicAuth"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask">
            <!--
                FIX #13: windowSoftInputMode="adjustResize" removed. On API 30+ it
                is a no-op when WindowInsets are in use (which this app sets via
                WindowInsetsController). The system keyboard overlay behaviour is
                correct for a full-screen WebView without it.
            -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                SHIELD TV FIX: LEANBACK_LAUNCHER makes the app appear in the
                Shield / Android TV app drawer after installation.  Without it
                the app installs but is invisible in the launcher — users can
                only open it via the deep link from Kodi (spydermusic://auth),
                which works, but makes first-run setup confusing.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>

            <!-- Deep link from Kodi: spydermusic://auth -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="spydermusic" android:host="auth" />
            </intent-filter>

        </activity>

    </application>

</manifest>
